{
  "expo": {
    "name": "QuiteZone",
    "slug": "NoiseHunterApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gold.noise.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "location",
          "fetch",
          "remote-notification"
        ],
        "NSMicrophoneUsageDescription": "نحتاج للوصول إلى الميكروفون لرصد مستويات الضوضاء"
      }
    },
    "android": {
      "package": "com.gold.noise.app",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBpiHiJwJ5VV7z77eWASVPUt3Xl5NPKb7c"
        }
      },
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE",
        "FOREGROUND_SERVICE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#00FFCC"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "نحتاج للوصول لموقعك لرسم خريطة الضوضاء حتى عند إغلاق التطبيق."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "8f65106e-feea-46d1-a5af-2949c829e0e8"
      }
    }
  }
}
